{
  "name": "eduidec-landing-page",
  "version": "1.0.0",
  "description": "Landing page for EduIDE Cloud workspace management",
  "license": "EPL-2.0 OR GPL-2.0 WITH Classpath-exception-2.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/EduIDE/EduIDE-Landing-Page.git"
  },
  "homepage": "https://github.com/EduIDE/EduIDE-Landing-Page#readme",
  "bugs": {
    "url": "https://github.com/EduIDE/EduIDE-Landing-Page/issues"
  },
  "keywords": [
    "theia",
    "cloud",
    "kubernetes",
    "landing-page",
    "react",
    "vite",
    "education"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --ext ts,tsx --fix",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\""
  },
  "dependencies": {
    "@eclipse-theiacloud/common": "1.2.0-next.83c8f60",
    "@sentry/react": "^10.51.0",
    "keycloak-js": "25.0.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.180.0",
    "vanta": "^0.5.24"
  },
  "devDependencies": {
    "@types/node": "^20.19.39",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "@vitejs/plugin-react": "^4.7.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^8.10.2",
    "eslint-import-resolver-typescript": "^3.10.1",
    "eslint-plugin-header": "^3.1.1",
    "eslint-plugin-import": "^2.26.0",
    "eslint-plugin-no-null": "^1.0.2",
    "eslint-plugin-prettier": "^4.2.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.26",
    "eslint-plugin-simple-import-sort": "^7.0.0",
    "prettier": "^2.8.8",
    "typescript": "^5.9.3",
    "vite": "^7.3.2"
  }
}
